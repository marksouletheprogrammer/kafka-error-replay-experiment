{
  "connector.class": "io.debezium.connector.jdbc.JdbcSinkConnector",
  "tasks.max": "1",
  "topics": "dlq-jdbc-sink-eligibility,dlq-jdbc-sink-claims,dlq-jdbc-sink-providers",
  "connection.url": "jdbc:postgresql://postgres:5432/appdb",
  "connection.username": "postgres",
  "connection.password": "postgres",
  "insert.mode": "upsert",
  "primary.key.mode": "record_value",
  "primary.key.fields": "id",
  "schema.evolution": "basic",
  "database.time_zone": "UTC",
  "table.name.format": "datastore.${topic}",
  "transforms": "stripDlqPrefix",
  "transforms.stripDlqPrefix.type": "org.apache.kafka.connect.transforms.RegexRouter",
  "transforms.stripDlqPrefix.regex": "dlq-jdbc-sink-(.*)",
  "transforms.stripDlqPrefix.replacement": "$1",
  "key.converter": "org.apache.kafka.connect.storage.StringConverter",
  "value.converter": "io.confluent.connect.avro.AvroConverter",
  "value.converter.schema.registry.url": "http://schema-registry:8081",
  "errors.tolerance": "all",
  "errors.deadletterqueue.topic.name": "dlq-replay-terminal",
  "errors.deadletterqueue.topic.replication.factor": "1",
  "errors.deadletterqueue.context.headers.enable": "true",
  "errors.log.enable": "true",
  "errors.log.include.messages": "true"
}
